{
  "name": "app",
  "version": "0.1.0",
  "description": "Doc Forge desktop and web client for conversational document authoring.",
  "author": "Doc Forge Team",
  "private": true,
  "main": "electron/main.mjs",
  "engines": {
    "node": ">=20 <26",
    "npm": ">=10 <11"
  },
  "scripts": {
    "dev": "next dev",
    "desktop:dev": "electron ./electron/main.mjs",
    "setup:local": "bash ./scripts/setup-local.sh",
    "start:local": "bash ./scripts/start-local.sh",
    "build": "next build",
    "build:desktop": "node ./scripts/sync-desktop-icon.mjs && npm run build && node ./scripts/prepare-standalone-assets.mjs",
    "start": "next start",
    "verify:build:platform:mac": "node ./scripts/check-build-platform.mjs mac",
    "verify:build:platform:win": "node ./scripts/check-build-platform.mjs win",
    "verify:signing:env:mac": "node ./scripts/check-signing-env.mjs mac",
    "verify:signing:env:win": "node ./scripts/check-signing-env.mjs win",
    "pack:dir": "npm run build:desktop && node ./scripts/run-electron-builder.mjs --dir --publish never",
    "dist:current": "npm run build:desktop && node ./scripts/run-electron-builder.mjs --publish never",
    "dist:mac": "npm run verify:build:platform:mac && npm run build:desktop && node ./scripts/run-electron-builder.mjs --mac dmg zip --publish never",
    "dist:win": "npm run verify:build:platform:win && npm run build:desktop && node ./scripts/run-electron-builder.mjs --win nsis zip --config.win.signAndEditExecutable=false --publish never",
    "dist:mac:signed": "npm run verify:build:platform:mac && npm run verify:signing:env:mac && npm run build:desktop && node ./scripts/run-electron-builder.mjs --mac dmg zip --publish never",
    "dist:win:signed": "npm run verify:build:platform:win && npm run verify:signing:env:win && npm run build:desktop && node ./scripts/run-electron-builder.mjs --win nsis zip --publish never",
    "lint": "eslint",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:desktop:smoke": "node ./scripts/run-desktop-smoke.mjs"
  },
  "build": {
    "appId": "com.docforge.app",
    "productName": "Doc Forge",
    "artifactName": "DocForge-${version}-${os}-${arch}.${ext}",
    "asar": false,
    "directories": {
      "output": "dist",
      "buildResources": "electron/assets"
    },
    "files": [
      "electron/**/*",
      ".next/standalone/**/*",
      "!.next/standalone/dist/**",
      "!.next/standalone/data/**",
      "!.next/standalone/test-results/**"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "icon.png",
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "electron/entitlements.mac.plist",
      "entitlementsInherit": "electron/entitlements.mac.plist"
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ],
      "icon": "icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@tailwindcss/typography": "^0.5.19",
    "better-sqlite3": "^12.6.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.1",
    "lucide-react": "^0.576.0",
    "next": "16.1.6",
    "pptxgenjs": "^4.0.1",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.7.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0",
    "uuid": "^13.0.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "drizzle-kit": "^0.31.9",
    "electron": "^40.8.0",
    "electron-builder": "^26.0.12",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  }
}
