# Optional. When unset, provider is auto-selected by available API keys:
# GEMINI_API_KEY (or GOOGLE_API_KEY) -> OPENAI_API_KEY -> ANTHROPIC_API_KEY.
# For local E2E without external API keys, set LLM_PROVIDER=mock.
LLM_PROVIDER=

ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key
GEMINI_API_KEY=your-gemini-api-key
# GOOGLE_API_KEY=your-google-api-key

# Optional model overrides
ANTHROPIC_MODEL=claude-sonnet-4-20250514
OPENAI_MODEL=gpt-4o-mini
GEMINI_MODEL=gemini-2.0-flash

# Optional DB override (useful for test isolation)
# DOC_FORGE_DB_PATH=data/doc-forge.local.db

# Optional encryption secret for stored LLM keys (UI settings)
# When unset, a local key file is auto-generated at data/.doc-forge-credentials.key
# DOC_FORGE_CREDENTIALS_SECRET=replace-with-strong-random-string
# DOC_FORGE_CREDENTIALS_SECRET_PATH=data/.doc-forge-credentials.key
